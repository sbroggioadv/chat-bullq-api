{
  "name": "chat-bullq-api",
  "version": "1.0.0",
  "description": "Chat BullQ — Omnichannel customer service API",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "sh scripts/prisma-deploy.sh",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "sh scripts/prisma-deploy.sh",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "start:prod:migrate": "sh scripts/start-prod-migrate.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "evals": "ts-node -P tsconfig.json --transpile-only src/modules/ai-agents/evals/cli.ts",
    "evals:agent": "ts-node -P tsconfig.json --transpile-only src/modules/ai-agents/evals/cli.ts --agent"
  },
  "type": "commonjs",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
