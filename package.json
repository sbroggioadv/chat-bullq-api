    "@types/pg": "^8.20.0",
    "@types/web-push": "^3.6.0",
    "jest": "^29.7.0",
    "prisma": "^6.19.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0"
  },
  "resolutions": {
    "defu": "6.1.7",
    "effect": "3.21.0",
    "fast-uri": "3.1.3",
    "follow-redirects": "1.16.0",
