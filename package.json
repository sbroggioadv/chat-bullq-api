    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.80.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "eta": "^4.6.0",
    "form-data": "^4.0.6",
    "helmet": "^8.0.0",
    "ioredis": "^5.0.0",
    "minio": "^8.0.7",
    "openai": "^6.35.0",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
