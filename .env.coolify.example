# Bullq2 — exemplo de env vars para Coolify
# Não commitar valores reais. Usar 1Password Claude-Code-Dev pra secrets.

# =============================================================================
# Database
# =============================================================================
POSTGRES_USER=bravy
POSTGRES_PASSWORD=__DEFINIR_NO_COOLIFY__
POSTGRES_DB=chat_bullq

# =============================================================================
# Redis (default sem password, está em rede privada do Coolify)
# =============================================================================

# =============================================================================
# JWT — DEVE SER DIFERENTE DO V1
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================================================
JWT_SECRET=__DEFINIR_NO_COOLIFY__
JWT_REFRESH_SECRET=__DEFINIR_NO_COOLIFY__
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# =============================================================================
# Encryption — 64 hex chars
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================
ENCRYPTION_KEY=__DEFINIR_NO_COOLIFY__

# =============================================================================
# CORS — incluir todos os domínios do web (separados por vírgula)
# =============================================================================
# FQDNs sslip.io removidos em S17/C2 (2026-05-13) — canônico = iacombativa.com.
CORS_ORIGIN=https://bullq.iacombativa.com

# =============================================================================
# MinIO
# =============================================================================
MINIO_ACCESS_KEY=bravy
MINIO_SECRET_KEY=__DEFINIR_NO_COOLIFY__
MINIO_BUCKET=chat-bullq

# =============================================================================
# Web Push (VAPID) — opcional
# Gerar com: npx web-push generate-vapid-keys --json
# =============================================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:doc@sbroggio.io

# =============================================================================
# OpenAI — só se usar AI agents
# =============================================================================
OPENAI_API_KEY=
AI_AGENT_ENABLED=false

# =============================================================================
# Google Drive — opcional, integrações
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.bullq.iacombativa.com/api/v1/integrations/google/callback

# =============================================================================
# Seeds — manter false em prod (admin é criado pelo Doc via UI)
# =============================================================================
SEED_ENABLED=false
ADMIN_INITIAL_PASSWORD=

# =============================================================================
# Logs
# =============================================================================
LOG_LEVEL=info
