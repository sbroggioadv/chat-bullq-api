generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────

enum OrgRole {
  OWNER
  ADMIN
  AGENT
}

enum AgentStatus {
  ONLINE
  AWAY
  OFFLINE
}

enum ChannelType {
  WHATSAPP_OFFICIAL
  WHATSAPP_ZAPPFY
  INSTAGRAM
}

enum ConversationStatus {
  PENDING
  BOT
  OPEN
  WAITING
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageContentType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  STICKER
  LOCATION
  REACTION
  TEMPLATE
  INTERACTIVE
  SYSTEM
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum DistributionRule {
  ROUND_ROBIN
  LEAST_BUSY
  MANUAL
}

enum ChatbotNodeType {
  START
  MESSAGE
  MENU
  CONDITION
  WAIT
  ACTION
  TRANSFER
  END_FLOW
}

enum NotificationType {
  NEW_MESSAGE
  CONVERSATION_ASSIGNED
  CONVERSATION_TRANSFERRED
  SLA_WARNING
  SLA_BREACH
  MENTION
  SYSTEM
}

// ─── Core: Auth + Multi-tenancy ──────────────────

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  avatarUrl String?   @map("avatar_url")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  organizations         UserOrganization[]
  assignedConversations Conversation[]     @relation("AssignedAgent")
  sentMessages          Message[]          @relation("MessageSender")
  notifications         Notification[]
  pushSubscriptions     PushSubscription[]
  sentInvitations       Invitation[]
  apiKeys               ApiKey[]

  @@map("users")
}

model Organization {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  logoUrl   String?   @map("logo_url")
  plan      String    @default("free")
  settings  Json      @default("{}")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // ─── AI settings ────────────────────────────────
  aiEnabled            Boolean @default(true)  @map("ai_enabled")
  aiTimezone           String  @default("America/Sao_Paulo") @map("ai_timezone")
  aiBusinessHours      Json?   @map("ai_business_hours")
  aiOutOfHoursMessage  String? @map("ai_out_of_hours_message")
  aiAutoDisableOnHuman Boolean @default(true)  @map("ai_auto_disable_on_human")
  aiMonthlyTokenCap    Int?    @map("ai_monthly_token_cap")

  members       UserOrganization[]
  channels      Channel[]
  contacts      Contact[]
  conversations Conversation[]
  departments   Department[]
  chatbotFlows  ChatbotFlow[]
  quickReplies  QuickReply[]
  tags          Tag[]
  notifications Notification[]
  invitations   Invitation[]
  apiKeys       ApiKey[]
  aiAgents      AiAgent[]

  @@map("organizations")
}

model UserOrganization {
  id             String      @id @default(cuid())
  userId         String      @map("user_id")
  organizationId String      @map("organization_id")
  role           OrgRole     @default(AGENT)
  agentStatus    AgentStatus @default(OFFLINE) @map("agent_status")
  maxConcurrent  Int         @default(5) @map("max_concurrent")
  preferences    Json        @default("{}")
  joinedAt       DateTime    @default(now()) @map("joined_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  departmentAgents DepartmentAgent[]
  channelAgents    ChannelAgent[]

  @@unique([userId, organizationId])
  @@map("user_organizations")
}

// ─── Invitations ────────────────────────────────

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Invitation {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  email          String
  role           OrgRole          @default(AGENT)
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  invitedById    String           @map("invited_by_id")
  expiresAt      DateTime         @map("expires_at")
  acceptedAt     DateTime?        @map("accepted_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([email, status], name: "idx_invitation_email_status")
  @@index([organizationId], name: "idx_invitation_org")
  @@map("invitations")
}

// ─── Channel Hub ─────────────────────────────────

model Channel {
  id             String      @id @default(cuid())
  organizationId String      @map("organization_id")
  type           ChannelType
  name           String
  config         Json
  webhookSecret  String?     @map("webhook_secret")
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactChannels ContactChannel[]
  conversations   Conversation[]
  chatbotFlows    ChatbotFlowChannel[]
  syncJobs        ChannelSyncJob[]
  channelAgents   ChannelAgent[]
  aiAgentChannels AiAgentChannel[]

  @@index([organizationId, type], name: "idx_channel_org_type")
  @@map("channels")
}

model ChannelAgent {
  id                 String   @id @default(cuid())
  channelId          String   @map("channel_id")
  userOrganizationId String   @map("user_organization_id")
  grantedAt          DateTime @default(now()) @map("granted_at")
  grantedById        String?  @map("granted_by_id")

  channel          Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userOrganization UserOrganization @relation(fields: [userOrganizationId], references: [id], onDelete: Cascade)

  @@unique([channelId, userOrganizationId])
  @@index([userOrganizationId], name: "idx_channel_agent_userorg")
  @@map("channel_agents")
}

// ─── Webhook Events (append-only audit + replay) ──

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
  UNROUTED
}

model WebhookEvent {
  id           String             @id @default(cuid())
  channelId    String?            @map("channel_id")
  channelType  ChannelType        @map("channel_type")
  status       WebhookEventStatus @default(RECEIVED)
  rawPayload   Json               @map("raw_payload")
  headers      Json               @default("{}")
  errorMessage String?            @map("error_message")
  receivedAt   DateTime           @default(now()) @map("received_at")
  processedAt  DateTime?          @map("processed_at")

  @@index([channelId, receivedAt(sort: Desc)], name: "idx_webhook_channel_time")
  @@index([channelType, status, receivedAt(sort: Desc)], name: "idx_webhook_type_status")
  @@map("webhook_events")
}

// ─── Channel Sync Jobs ───────────────────────────

enum ChannelSyncStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ChannelSyncMode {
  INITIAL
  MANUAL
  DELTA
}

model ChannelSyncJob {
  id                    String            @id @default(cuid())
  channelId             String            @map("channel_id")
  status                ChannelSyncStatus @default(PENDING)
  mode                  ChannelSyncMode   @default(INITIAL)
  lookbackDays          Int               @default(90) @map("lookback_days")
  startedAt             DateTime?         @map("started_at")
  finishedAt            DateTime?         @map("finished_at")
  conversationsTotal    Int               @default(0) @map("conversations_total")
  conversationsImported Int               @default(0) @map("conversations_imported")
  messagesImported      Int               @default(0) @map("messages_imported")
  contactsImported      Int               @default(0) @map("contacts_imported")
  errorMessage          String?           @map("error_message")
  lastCursor            String?           @map("last_cursor")
  metadata              Json              @default("{}")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt(sort: Desc)], name: "idx_sync_channel_time")
  @@index([status], name: "idx_sync_status")
  @@map("channel_sync_jobs")
}

// ─── Contacts ────────────────────────────────────

model Contact {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  name           String?
  phone          String?
  email          String?
  avatarUrl      String?   @map("avatar_url")
  notes          String?
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization  Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channels      ContactChannel[]
  conversations Conversation[]
  tags          ContactTag[]
  aiMemories    AiAgentMemory[]

  @@index([organizationId, phone], name: "idx_contact_org_phone")
  @@index([organizationId, email], name: "idx_contact_org_email")
  @@map("contacts")
}

model ContactChannel {
  id               String   @id @default(cuid())
  contactId        String   @map("contact_id")
  channelId        String   @map("channel_id")
  externalId       String   @map("external_id")
  profileName      String?  @map("profile_name")
  profileAvatarUrl String?  @map("profile_avatar_url")
  createdAt        DateTime @default(now()) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, externalId], name: "uq_contact_channel_external")
  @@map("contact_channels")
}

// ─── Conversations ───────────────────────────────

model Conversation {
  id              String             @id @default(cuid())
  organizationId  String             @map("organization_id")
  channelId       String             @map("channel_id")
  contactId       String             @map("contact_id")
  assignedToId    String?            @map("assigned_to_id")
  departmentId    String?            @map("department_id")
  status          ConversationStatus @default(PENDING)
  subject         String?
  protocol        String?
  isGroup         Boolean            @default(false) @map("is_group")
  lastMessageAt   DateTime?          @map("last_message_at")
  firstResponseAt DateTime?          @map("first_response_at")
  closedAt        DateTime?          @map("closed_at")
  reopenedAt      DateTime?          @map("reopened_at")
  reopenedCount   Int                @default(0) @map("reopened_count")
  deletedAt       DateTime?          @map("deleted_at")
  metadata        Json               @default("{}")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  // ─── AI state ───────────────────────────────────
  aiEnabled       Boolean   @default(true)  @map("ai_enabled")
  aiDisabledBy    String?   @map("ai_disabled_by")
  aiDisabledAt    DateTime? @map("ai_disabled_at")
  activeAgentId   String?   @map("active_agent_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel      Channel      @relation(fields: [channelId], references: [id])
  contact      Contact      @relation(fields: [contactId], references: [id])
  assignedTo   User?        @relation("AssignedAgent", fields: [assignedToId], references: [id], onDelete: SetNull)
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  activeAgent  AiAgent?     @relation("ActiveAgent", fields: [activeAgentId], references: [id], onDelete: SetNull)

  messages      Message[]
  tags          ConversationTag[]
  internalNotes InternalNote[]
  auditLogs     ConversationAuditLog[]
  rating        ConversationRating?
  aiRuns        AiAgentRun[]
  aiHandoffs    AiAgentHandoff[]

  @@index([organizationId, status], name: "idx_conv_org_status")
  @@index([organizationId, assignedToId], name: "idx_conv_org_agent")
  @@index([organizationId, channelId], name: "idx_conv_org_channel")
  @@index([contactId], name: "idx_conv_contact")
  @@index([lastMessageAt], name: "idx_conv_last_msg")
  @@map("conversations")
}

model ConversationRating {
  id             String    @id @default(cuid())
  conversationId String    @unique @map("conversation_id")
  organizationId String    @map("organization_id")
  agentId        String?   @map("agent_id")
  score          Int
  comment        String?
  token          String    @unique
  requestedAt    DateTime  @default(now()) @map("requested_at")
  respondedAt    DateTime? @map("responded_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([organizationId, respondedAt], name: "idx_rating_org_responded")
  @@index([organizationId, agentId], name: "idx_rating_org_agent")
  @@map("conversation_ratings")
}

model ConversationAuditLog {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  actorId        String?  @map("actor_id")
  action         String
  fromValue      String?  @map("from_value")
  toValue        String?  @map("to_value")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt], name: "idx_audit_conv_time")
  @@map("conversation_audit_logs")
}

model InternalNote {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  authorId       String   @map("author_id")
  content        String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("internal_notes")
}

// ─── Messages ────────────────────────────────────

model Message {
  id             String             @id @default(cuid())
  conversationId String             @map("conversation_id")
  direction      MessageDirection
  type           MessageContentType
  content        Json
  externalId     String?            @map("external_id")
  status         MessageStatus      @default(QUEUED)
  senderName     String?            @map("sender_name")
  senderId       String?            @map("sender_id")
  sentAt         DateTime?          @map("sent_at")
  deliveredAt    DateTime?          @map("delivered_at")
  readAt         DateTime?          @map("read_at")
  failedReason   String?            @map("failed_reason")
  metadata       Json               @default("{}")
  createdAt      DateTime           @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation("MessageSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@unique([conversationId, externalId], name: "uq_msg_conv_external")
  @@index([conversationId, createdAt], name: "idx_msg_conv_time")
  @@index([externalId], name: "idx_msg_external_id")
  @@map("messages")
}

// ─── Departments / Routing ───────────────────────

model Department {
  id               String           @id @default(cuid())
  organizationId   String           @map("organization_id")
  name             String
  description      String?
  distributionRule DistributionRule @default(ROUND_ROBIN) @map("distribution_rule")
  isDefault        Boolean          @default(false) @map("is_default")
  slaFirstResponse Int?             @map("sla_first_response")
  slaResolution    Int?             @map("sla_resolution")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  deletedAt        DateTime?        @map("deleted_at")

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agents        DepartmentAgent[]
  conversations Conversation[]

  @@map("departments")
}

model DepartmentAgent {
  id                 String  @id @default(cuid())
  departmentId       String  @map("department_id")
  userOrganizationId String  @map("user_organization_id")
  isActive           Boolean @default(true) @map("is_active")

  department       Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userOrganization UserOrganization @relation(fields: [userOrganizationId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userOrganizationId])
  @@map("department_agents")
}

// ─── Chatbot ─────────────────────────────────────

model ChatbotFlow {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  name           String
  description    String?
  isActive       Boolean   @default(false) @map("is_active")
  triggerType    String    @default("KEYWORD") @map("trigger_type")
  triggerConfig  Json      @default("{}") @map("trigger_config")
  variables      Json      @default("[]")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  nodes        ChatbotNode[]
  channels     ChatbotFlowChannel[]

  @@map("chatbot_flows")
}

model ChatbotNode {
  id        String          @id @default(cuid())
  flowId    String          @map("flow_id")
  type      ChatbotNodeType
  name      String?
  positionX Float           @default(0) @map("position_x")
  positionY Float           @default(0) @map("position_y")
  data      Json            @default("{}")
  edges     Json            @default("[]")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  flow ChatbotFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@map("chatbot_nodes")
}

model ChatbotFlowChannel {
  flowId    String @map("flow_id")
  channelId String @map("channel_id")

  flow    ChatbotFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  channel Channel     @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([flowId, channelId])
  @@map("chatbot_flow_channels")
}

// ─── Quick Replies ───────────────────────────────

model QuickReply {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  shortcut       String
  title          String
  content        String
  attachments    Json      @default("[]")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, shortcut])
  @@map("quick_replies")
}

// ─── Tags ────────────────────────────────────────

model Tag {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  name           String
  color          String @default("#6B7280")

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations ConversationTag[]
  contacts      ContactTag[]

  @@unique([organizationId, name])
  @@map("tags")
}

model ConversationTag {
  conversationId String @map("conversation_id")
  tagId          String @map("tag_id")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tag          Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([conversationId, tagId])
  @@map("conversation_tags")
}

model ContactTag {
  contactId String @map("contact_id")
  tagId     String @map("tag_id")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("contact_tags")
}

// ─── Notifications ───────────────────────────────

model Notification {
  id             String           @id @default(cuid())
  recipientId    String           @map("recipient_id")
  organizationId String           @map("organization_id")
  type           NotificationType
  title          String
  body           String
  data           Json             @default("{}")
  isRead         Boolean          @default(false) @map("is_read")
  readAt         DateTime?        @map("read_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  recipient    User         @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([recipientId, isRead, createdAt], name: "idx_notif_user_unread")
  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dhKey String   @map("p256dh_key")
  authKey   String   @map("auth_key")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_push_sub_user")
  @@map("push_subscriptions")
}

model NotificationPreference {
  id             String           @id @default(cuid())
  userId         String           @map("user_id")
  organizationId String           @map("organization_id")
  type           NotificationType
  inApp          Boolean          @default(true) @map("in_app")
  browserPush    Boolean          @default(true) @map("browser_push")
  sound          Boolean          @default(true)
  dndStart       String?          @map("dnd_start")
  dndEnd         String?          @map("dnd_end")

  @@unique([userId, organizationId, type])
  @@map("notification_preferences")
}

// ─── API Keys (pk_token) ─────────────────────────

model ApiKey {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  userId         String    @map("user_id")
  name           String
  prefix         String    @db.VarChar(12)
  hashedKey      String    @unique @map("hashed_key")
  lastUsedAt     DateTime? @map("last_used_at")
  expiresAt      DateTime? @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId], name: "idx_apikey_org")
  @@index([userId], name: "idx_apikey_user")
  @@index([hashedKey], name: "idx_apikey_hash")
  @@map("api_keys")
}

// ═══════════════════════════════════════════════════
// AI AGENTS
// ═══════════════════════════════════════════════════

enum AiAgentKind {
  ORCHESTRATOR
  WORKER
}

enum AiAgentMode {
  AUTONOMOUS
  COPILOT
  DISABLED
}

enum AiAgentTrigger {
  ALWAYS
  OFF_HOURS
  NO_HUMAN_ASSIGNED
}

enum AiRunStatus {
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum AiFinalAction {
  REPLIED
  DELEGATED
  HANDED_BACK
  TRANSFERRED_TO_HUMAN
  CLOSED_CONVERSATION
  NO_ACTION
}

model AiAgent {
  id             String      @id @default(cuid())
  organizationId String      @map("organization_id")
  name           String
  description    String?
  avatarUrl      String?     @map("avatar_url")

  kind           AiAgentKind @default(WORKER)
  category       String?
  capabilities   String[]    @default([])

  modelId        String      @map("model_id")
  modelParams    Json?       @map("model_params")
  systemPrompt   String      @map("system_prompt")
  temperature    Float       @default(0.7)
  maxTokens      Int         @default(2048) @map("max_tokens")

  canRespondDirectly Boolean @default(true) @map("can_respond_directly")
  isActive       Boolean     @default(true) @map("is_active")

  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  channels       AiAgentChannel[]
  memories       AiAgentMemory[]
  runs           AiAgentRun[]
  handoffsFrom   AiAgentHandoff[]  @relation("HandoffFrom")
  handoffsTo     AiAgentHandoff[]  @relation("HandoffTo")
  activeOn       Conversation[]    @relation("ActiveAgent")

  @@index([organizationId], name: "idx_ai_agent_org")
  @@index([organizationId, kind], name: "idx_ai_agent_org_kind")
  @@map("ai_agents")
}

model AiAgentChannel {
  id        String         @id @default(cuid())
  agentId   String         @map("agent_id")
  channelId String         @map("channel_id")
  mode      AiAgentMode    @default(AUTONOMOUS)
  trigger   AiAgentTrigger @default(ALWAYS)

  createdAt DateTime       @default(now()) @map("created_at")

  agent     AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([agentId, channelId])
  @@index([channelId], name: "idx_ai_agent_channel_channel")
  @@map("ai_agent_channels")
}

model AiAgentMemory {
  id                String   @id @default(cuid())
  agentId           String   @map("agent_id")
  contactId         String   @map("contact_id")
  summary           String?
  facts             Json     @default("{}")
  totalInteractions Int      @default(0) @map("total_interactions")
  lastInteractionAt DateTime? @map("last_interaction_at")

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  agent             AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  contact           Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([agentId, contactId])
  @@index([agentId], name: "idx_ai_memory_agent")
  @@index([contactId], name: "idx_ai_memory_contact")
  @@map("ai_agent_memories")
}

model AiAgentRun {
  id               String        @id @default(cuid())
  organizationId   String        @map("organization_id")
  conversationId   String        @map("conversation_id")
  agentId          String        @map("agent_id")
  triggerMessageId String?       @map("trigger_message_id")

  status           AiRunStatus   @default(RUNNING)
  finalAction      AiFinalAction? @map("final_action")
  errorMessage     String?       @map("error_message")

  modelId          String        @map("model_id")
  inputTokens      Int           @default(0) @map("input_tokens")
  outputTokens     Int           @default(0) @map("output_tokens")
  cacheReadTokens  Int           @default(0) @map("cache_read_tokens")
  cacheWriteTokens Int           @default(0) @map("cache_write_tokens")
  costUsd          Decimal       @default(0) @map("cost_usd") @db.Decimal(10, 6)
  durationMs       Int?          @map("duration_ms")

  startedAt        DateTime      @default(now()) @map("started_at")
  finishedAt       DateTime?     @map("finished_at")

  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agent            AiAgent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  toolCalls        AiToolCall[]

  @@index([organizationId, startedAt], name: "idx_ai_run_org_time")
  @@index([conversationId], name: "idx_ai_run_conv")
  @@index([agentId], name: "idx_ai_run_agent")
  @@map("ai_agent_runs")
}

model AiToolCall {
  id         String   @id @default(cuid())
  runId      String   @map("run_id")
  toolName   String   @map("tool_name")
  input      Json
  output     Json?
  error      String?
  durationMs Int?     @map("duration_ms")
  createdAt  DateTime @default(now()) @map("created_at")

  run        AiAgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId], name: "idx_ai_tool_call_run")
  @@map("ai_tool_calls")
}

model AiAgentHandoff {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  fromAgentId    String?  @map("from_agent_id")
  toAgentId      String   @map("to_agent_id")
  reason         String?
  briefing       String?
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  fromAgent    AiAgent?     @relation("HandoffFrom", fields: [fromAgentId], references: [id], onDelete: SetNull)
  toAgent      AiAgent      @relation("HandoffTo", fields: [toAgentId], references: [id], onDelete: Cascade)

  @@index([conversationId], name: "idx_ai_handoff_conv")
  @@map("ai_agent_handoffs")
}
