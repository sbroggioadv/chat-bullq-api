NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://bravy:bravy123@localhost:5432/chat_bullq

# JWT
JWT_SECRET=change-me-generate-with-node-e-require-crypto-randomBytes-64-toString-hex
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=change-me-generate-another-different-one
