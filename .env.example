NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://bravy:bravy123@localhost:5432/chat_bullq
# Direct database URL for Prisma migrations. In local/dev it can match DATABASE_URL.
# In Supabase, use the direct/session connection here and keep pooled runtime in DATABASE_URL.
DIRECT_URL=postgresql://bravy:bravy123@localhost:5432/chat_bullq

# JWT
JWT_SECRET=change-me-generate-with-node-e-require-crypto-randomBytes-64-toString-hex
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=change-me-generate-another-different-one
JWT_REFRESH_EXPIRATION=7d

# Redis
# Use REDIS_URL for managed Redis. rediss:// enables TLS automatically.
# Example: rediss://default:password@host:6380/0
# REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_TLS=false

# Socket.IO cross-instance events. Automatically enabled when REDIS_URL is set.
# Set this to true if using REDIS_HOST/REDIS_PORT in a multi-instance runtime.
SOCKET_IO_REDIS_ADAPTER=false

# CORS
CORS_ORIGIN=http://localhost:3000

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=bravy
MINIO_SECRET_KEY=bravy123minio
MINIO_BUCKET=chat-bullq
# Opcional (defaults: useSSL=false, region=us-east-1).
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@bravy.com

OPENAI_API_KEY=sk-proj-your-key-here
ZAI_API_KEY=sk-your-zai-key-here
